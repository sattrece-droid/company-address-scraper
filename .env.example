# Backend Configuration

# SerpAPI - Company website search
# Sign up at https://serpapi.com
SERPAPI_KEY=your_serpapi_key_here

# Firecrawl - Web scraping
# Sign up at https://www.firecrawl.dev
FIRECRAWL_API_KEY=your_firecrawl_key_here

# AWS Bedrock - Address parsing (Nova Micro model)
# Set up at https://aws.amazon.com/bedrock
AWS_ACCESS_KEY_ID=your_access_key_here
AWS_SECRET_ACCESS_KEY=your_secret_key_here
AWS_DEFAULT_REGION=us-east-1

# Application Settings
ENVIRONMENT=production
MAX_COMPANIES_PER_REQUEST=10
CACHE_TTL_DAYS=7
MAX_CONCURRENT_PLAYWRIGHT=1
DAILY_COMPANY_LIMIT_PER_IP=10

# Frontend Configuration

# Google AdSense (optional)
# Sign up at https://adsense.google.com
NEXT_PUBLIC_ADSENSE_ID=
